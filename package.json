{
  "name": "ai-teams",
  "version": "0.3.3",
  "private": true,
  "description": "Local-first multi-agent terminal workspace",
  "main": "src/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dev:demo": "python3 aiteam.py --root .aiteam-demo init --demo --force && AITEAMS_WORKSPACE_ROOT=.aiteam-demo concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "smoke": "npm run smoke:role-import && npm run smoke:role-config && npm run smoke:role-runtime && npm run smoke:model-inject && npm run smoke:model-inject-app && npm run smoke:role-inject && npm run smoke:role-inject-app && npm run smoke:role-hire && npm run smoke:tmux && npm run smoke:tmux-view && npm run smoke:tmux-input && npm run smoke:agent-input-queue && npm run smoke:tmux-recovery && npm run smoke:tmux-zombie-recovery && npm run smoke:tmux-runtime-unit && npm run smoke:process-tree && npm run smoke:terminal-wheel && npm run smoke:agent-detect && npm run smoke:logger",
    "smoke:pty": "python3 aiteam.py --root .aiteam-demo init --demo --force && node scripts/desktop-pty-smoke.cjs",
    "smoke:role-inject": "python3 scripts/role-inject-smoke.py",
    "smoke:role-inject-app": "node scripts/role-inject-app-smoke.cjs",
    "smoke:role-hire": "python3 scripts/role-hire-smoke.py",
    "smoke:role-import": "python3 scripts/role-import-smoke.py",
    "smoke:role-config": "node scripts/role-config-smoke.cjs",
    "smoke:role-runtime": "node scripts/role-runtime-smoke.cjs",
    "smoke:model-inject": "python3 scripts/model-inject-smoke.py",
    "smoke:model-inject-app": "node scripts/model-inject-app-smoke.cjs",
    "smoke:tmux": "node scripts/tmux-runtime-smoke.cjs",
    "smoke:tmux-input": "node scripts/tmux-input-fallback-smoke.cjs",
    "smoke:agent-input-queue": "node scripts/agent-input-queue-smoke.cjs",
    "smoke:tmux-recovery": "node scripts/tmux-runtime-recovery-smoke.cjs",
    "smoke:tmux-zombie-recovery": "node scripts/tmux-zombie-recovery-smoke.cjs",
    "smoke:tmux-runtime-unit": "node scripts/tmux-runtime-unit-smoke.cjs",
    "smoke:process-tree": "node scripts/process-tree-smoke.cjs",
    "smoke:tmux-view": "node scripts/tmux-view-smoke.cjs",
    "smoke:terminal-wheel": "node scripts/terminal-wheel-smoke.mjs",
    "smoke:agent-detect": "node scripts/agent-detect-smoke.cjs",
    "smoke:logger": "node scripts/logger-smoke.cjs",
    "release:check": "node scripts/release-check.cjs",
    "release:check:full": "node scripts/release-check.cjs --full",
    "package:mac:local": "node scripts/package-macos-local.cjs",
    "package:mac:dmg": "node scripts/package-macos-local.cjs --dmg",
    "preview": "vite preview --host 127.0.0.1",
    "doctor": "python3 aiteam.py doctor"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-log": "^5.4.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  }
}
